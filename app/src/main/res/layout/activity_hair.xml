<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    tools:context=".Hair">

    <Button
        android:id="@+id/searchName"
        android:layout_width="113dp"
        android:layout_height="64dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/btn_rounded"
        android:backgroundTint="#FCCFDE"
        android:text="search by       product description" />

    <Button
        android:id="@+id/searchCompanyName"
        android:layout_width="113dp"
        android:layout_height="64dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_centerHorizontal="true"
        android:layout_gravity="center"
        android:layout_marginTop="1dp"
        android:layout_marginEnd="145dp"
        android:background="@drawable/btn_rounded"
        android:backgroundTint="#FCCFDE"
        android:text="search by company name" />

    <Button
        android:id="@+id/searchPrice"
        android:layout_width="113dp"
        android:layout_height="64dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="1dp"
        android:background="@drawable/btn_rounded"
        android:backgroundTint="#FCCFDE"
        android:text="search by       price" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/text_view_range"
        android:text="0-400"
        android:textSize="50sp"
        android:gravity="center"
        android:layout_below="@+id/searchPrice"/>


    <me.bendik.simplerangeview.SimpleRangeView
        android:id="@+id/range_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/text_view_range"
        app:activeLineColor="#FCCFDE"
        app:count="9"
        app:tickColor="@color/pink"
        app:activeFocusThumbColor="@color/pink"
        app:labelColor="@color/pink"
        app:activeThumbColor="@color/pink"
        app:activeLabelColor="@color/pink"
        app:fixedLabelColor="@color/pink"
        app:fixedThumbColor="@color/pink"
        app:fixedThumbLabelColor="@color/pink"
        android:outlineSpotShadowColor="@color/pink"
        app:movable="true" />

    <ListView
        android:id="@+id/listview"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_alignParentStart="true"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="-82dp"
        android:layout_below="@+id/range_bar">

    </ListView>
</RelativeLayout>