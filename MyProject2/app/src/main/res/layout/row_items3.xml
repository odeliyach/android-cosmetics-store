<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:contentPadding="5dp"
    app:cardElevation="3dp"
    app:cardCornerRadius="3dp"
    app:cardUseCompatPadding="true"
    >

    <LinearLayout
        android:layout_width="411dp"
        android:layout_height="117dp"
        android:background="#F0D9FA"
        android:baselineAligned="false"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageView
            android:id="@+id/imageView"
            android:layout_width="90dp"
            android:layout_height="99dp"
            android:contentDescription="@string/todo"
            android:src="@drawable/p3" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="93dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/costomerName"
                android:layout_width="153dp"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_alignParentEnd="true"
                android:layout_marginStart="117dp"
                android:layout_marginLeft="5dp"
                android:layout_marginEnd="19dp"
                android:layout_marginRight="5dp"
                android:layout_marginBottom="5dp"
                android:text="Costomer Name"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/n1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_alignParentEnd="true"
                android:layout_marginStart="-1dp"
                android:layout_marginLeft="-283dp"
                android:layout_marginEnd="142dp"
                android:layout_marginRight="5dp"
                android:layout_marginBottom="5dp"
                android:text="Costomer Name:"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/n4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/n3"
                android:layout_alignTop="@+id/numberOfItems"
                android:layout_alignParentStart="true"
                android:layout_marginStart="1dp"
                android:layout_marginLeft="-262dp"
                android:layout_marginTop="-1dp"
                android:layout_marginEnd="13dp"
                android:layout_marginBottom="5dp"
                android:layout_toRightOf="@+id/numberOfItems"
                android:text="Number of items:"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/n3"
                android:layout_width="103dp"
                android:layout_height="wrap_content"
                android:layout_below="@+id/n1"
                android:layout_alignTop="@+id/numberOfItems"
                android:layout_alignParentStart="true"
                android:layout_marginStart="2dp"
                android:layout_marginLeft="-156dp"
                android:layout_marginTop="-23dp"
                android:layout_marginEnd="19dp"
                android:layout_marginBottom="-10dp"
                android:layout_toRightOf="@+id/orderPrice"
                android:text="Price:"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/numberOfItems"
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:layout_below="@+id/orderPrice"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="3dp"
                android:layout_marginEnd="26dp"
                android:layout_marginBottom="5dp"
                android:text="Number Of Items"
                android:textSize="15sp"
                android:textStyle="bold"

                />

            <TextView
                android:id="@+id/orderPrice"
                android:layout_width="115dp"
                android:layout_height="wrap_content"
                android:layout_below="@id/costomerName"
                android:layout_alignParentStart="true"
                android:layout_alignParentEnd="true"
                android:layout_marginStart="43dp"
                android:layout_marginTop="-4dp"
                android:layout_marginEnd="131dp"
                android:text="Price"
                android:textSize="15sp"
                android:textStyle="bold" />

        </RelativeLayout>


    </LinearLayout>

</androidx.cardview.widget.CardView>