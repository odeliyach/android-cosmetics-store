<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/merble"
    tools:context=".Perfumes">

    <ImageView
        android:id="@+id/imagePerfume"
        android:layout_width="wrap_content"
        android:layout_height="239dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="-5dp"
        android:layout_marginTop="-20dp"
        android:layout_marginEnd="-1dp"
        android:paddingBottom="40dp"
        android:src="@drawable/perfumes"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0" />

    <TextView
        android:id="@+id/male_perfume_and_fragrance"
        android:layout_width="311dp"
        android:layout_height="55dp"
        android:layout_below="@+id/perfumeMan"
        android:layout_alignParentEnd="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="-31dp"
        android:layout_marginEnd="50dp"
        android:text="Male Perfume and Fagrance"
        android:textAppearance="@style/TextAppearance.AppCompat.Large" />

    <ImageView
        android:id="@+id/perfumeMan"
        android:layout_width="331dp"
        android:layout_height="223dp"
        android:layout_below="@+id/perfumeWoman"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_centerHorizontal="true"
        android:layout_marginStart="26dp"
        android:layout_marginTop="-40dp"
        android:layout_marginEnd="54dp"
        android:backgroundTint="#00673AB7"
        android:paddingBottom="40dp"
        android:src="@drawable/download"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.18" />

    <ImageView
        android:id="@+id/perfumeWoman"
        android:layout_width="336dp"
        android:layout_height="220dp"
        android:layout_below="@+id/woman_perfume_and_fragrance"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_centerHorizontal="true"
        android:layout_marginStart="23dp"
        android:layout_marginTop="-20dp"
        android:layout_marginEnd="52dp"
        android:backgroundTint="#00673AB7"
        android:paddingBottom="40dp"
        android:src="@drawable/images147"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.18" />

    <TextView
        android:id="@+id/woman_perfume_and_fragrance"
        android:layout_width="326dp"
        android:layout_height="67dp"
        android:layout_below="@+id/imagePerfume"
        android:layout_alignParentEnd="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="-27dp"
        android:layout_marginEnd="34dp"
        android:text="Woman Perfume and Fragrance"
        android:textAppearance="@style/TextAppearance.AppCompat.Large" />

</RelativeLayout>
